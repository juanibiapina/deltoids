---
const features: { icon: string; title: string; body: string }[] = [
  {
    icon: "{ }",
    title: "Tree-sitter context",
    body:
      "Every hunk expands to the enclosing function, class, or impl. Real syntax, not regex.",
  },
  {
    icon: "diff",
    title: "Drop-in pager",
    body:
      "Pipe `git diff`, `gh pr diff`, or anything that emits unified diff. Configurable as the default git pager.",
  },
  {
    icon: "lazy",
    title: "Pairs with lazygit",
    body:
      "Set `git.paging.pager: deltoids` in lazygit config and every diff view inherits the wider context.",
  },
  {
    icon: "tui",
    title: "edit-tui for agents",
    body:
      "Browse every edit a coding agent made, with the reason and semantic scope. Three-pane lazygit-inspired layout.",
  },
  {
    icon: "rs go py",
    title: "Many languages",
    body:
      "Rust, Go, JavaScript, TypeScript, Python, Ruby, Java, C, C++. Falls back to plain context for everything else.",
  },
  {
    icon: "log",
    title: "Trace stored on disk",
    body:
      "edit-tui replays JSONL traces from `$XDG_DATA_HOME/edit/traces/`. Diff again any time. No vendor lock-in.",
  },
];
---

<section id="features" class="section">
  <div class="container">
    <div class="section-head">
      <h2>Built for one thing, done well</h2>
      <p>Wider context. Same diff. Nothing else.</p>
    </div>

    <div class="features-grid">
      {
        features.map((f) => (
          <article class="feature-card">
            <span class="feature-icon">{f.icon}</span>
            <h3>{f.title}</h3>
            <p set:html={f.body.replaceAll(/`([^`]+)`/g, "<code>$1</code>")} />
          </article>
        ))
      }
    </div>
  </div>
</section>
