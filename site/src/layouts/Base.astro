---
import "../styles/global.css";
import { SITE, NAV_LINKS } from "../data/site";
import DeltoidsMark from "../components/DeltoidsMark.astro";
import GitHubIcon from "../components/GitHubIcon.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const fullTitle = title
  ? `${title} · ${SITE.name}`
  : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux",
  softwareVersion: SITE.version,
  license: `${SITE.repo.url}/blob/main/LICENSE`,
  author: {
    "@type": "Person",
    name: SITE.author.name,
    url: SITE.author.url,
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author.name} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" sizes="any" href="/favicon.ico" />

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/ibm-plex-sans-latin.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/jetbrains-mono-latin.woff2"
      crossorigin
    />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#1a1b26" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="nav-brand" href="/">
          <DeltoidsMark />
          <span>{SITE.name}</span>
        </a>

        <nav aria-label="Primary">
          <ul class="nav-links">
            {
              NAV_LINKS.map((l) => (
                <li>
                  <a href={l.href}>{l.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>

        <div class="nav-actions">
          <a
            class="nav-icon-link"
            href={SITE.repo.url}
            target="_blank"
            rel="noreferrer"
            aria-label="GitHub repository"
          >
            <GitHubIcon />
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <div>
          <span style="color: var(--text)">{SITE.name}</span>
          <span class="sep"> · </span>
          <span>diffs for the agentic era</span>
        </div>
        <a
          href={`${SITE.repo.url}/blob/main/LICENSE`}
          target="_blank"
          rel="noreferrer"
        >
          {SITE.license} licensed
        </a>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const COPY_ICON =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        const CHECK_ICON =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
        const writeClipboard = async (text) => {
          if (navigator.clipboard && window.isSecureContext) {
            try {
              await navigator.clipboard.writeText(text);
              return true;
            } catch {}
          }
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.setAttribute("readonly", "");
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          let ok = false;
          try {
            ok = document.execCommand("copy");
          } catch {}
          document.body.removeChild(ta);
          return ok;
        };
        const makeCopyButton = () => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "cmd-copy";
          btn.setAttribute("aria-label", "Copy");
          btn.setAttribute("title", "Copy");
          btn.innerHTML = COPY_ICON;
          return btn;
        };
        const wireCopy = (btn, host, getText) => {
          btn.addEventListener("click", async (e) => {
            e.stopPropagation();
            if (!(await writeClipboard(getText()))) return;
            host.dataset.copied = "1";
            btn.innerHTML = CHECK_ICON;
            btn.setAttribute("aria-label", "Copied");
            setTimeout(() => {
              host.removeAttribute("data-copied");
              btn.innerHTML = COPY_ICON;
              btn.setAttribute("aria-label", "Copy");
            }, 1200);
          });
        };
        document.querySelectorAll(".cmd-line").forEach((el) => {
          const btn = makeCopyButton();
          el.appendChild(btn);
          wireCopy(btn, el, () => {
            const spans = el.querySelectorAll("span");
            return (
              spans.length
                ? [...spans].map((s) => s.textContent.trim()).join("\n")
                : el.textContent.trim()
            ).trim();
          });
        });
        document.querySelectorAll("pre").forEach((pre) => {
          const code = pre.querySelector("code");
          if (!code) return;
          const wrap = document.createElement("div");
          wrap.className = "code-block";
          pre.replaceWith(wrap);
          wrap.appendChild(pre);
          const btn = makeCopyButton();
          wrap.appendChild(btn);
          wireCopy(btn, wrap, () => code.textContent.replace(/\s+$/, ""));
        });
      })();
    </script>
  </body>
</html>
